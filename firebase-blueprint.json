{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Represents a restaurant owner's account.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "whatsapp": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["ownerId", "name", "slug"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "Restaurant menu item.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order.",
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "total": { "type": "number" },
        "customerPhone": { "type": "string" }
      },
      "required": ["status", "total"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Tenant documents"
    },
    "/tenants/{tenantId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "Categories for a tenant"
    },
    "/tenants/{tenantId}/products/{productId}": {
      "schema": "Product",
      "description": "Products for a tenant"
    },
    "/tenants/{tenantId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders for a tenant"
    }
  }
}
